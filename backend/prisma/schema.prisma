datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  notes     Note[]
}

model Note {
  id        String   @id @default(uuid())
  title     String
  content   String?
  userId    String
  colorId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime? 

  user      User @relation(fields: [userId], references: [id])
  sharedWith String[] @default([]) // Array of user IDs the note is shared with
  isShared   Boolean  @default(false) // Indicates if the note is shared
}
