datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  notes     Note[]
}

model Note {
  id        String   @id @default(uuid())
  title     String
  content   String?
  userId    String
  colorId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime?
  deletedAt DateTime? 

  user      User @relation(fields: [userId], references: [id])
}